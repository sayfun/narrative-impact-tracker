# .streamlit/secrets.toml.example
# Copy this to .streamlit/secrets.toml for local use.
# On Streamlit Cloud, set these in the app's Secrets panel instead.
# Currently this app uses only public APIs so no secrets are required.
# If you add NewsAPI or MediaCloud later, add keys here:

# [newsapi]
# key = "your_newsapi_key_here"

# [mediacloud]
# key = "your_mediacloud_api_key_here"
